rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - email: string (required) - User email
    //   - displayName: string (required) - User display name
    //   - role: string (required) - 'admin' or 'user'
    //   - balance: number (required) - User balance
    //   - debt: number (required) - User debt
    //   - points: number (required) - User points
    //   - completedModules: list (required) - List of module IDs
    //   - achievements: list (required) - List of achievement IDs
    //   - streak: number (required) - User daily streak
    //   - lastActive: string (required) - ISO 8601 timestamp
    //   - publicKey: string (optional) - PGP public key
    //   - privateKey: string (optional) - PGP private key (encrypted)
    //   - codename: string (optional) - Secret alias for terminal chat
    //
    // [Other collections documented as needed...]
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "uwikundac5@gmail.com" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'role', 'status', 'balance', 'debt', 'points', 'completedModules', 'achievements', 'streak', 'lastActive', 'publicKey', 'privateKey', 'codename']) &&
             data.uid is string &&
             data.email is string &&
             data.displayName is string &&
             data.role in ['admin', 'user'] &&
             data.status in ['active', 'banned'] &&
             data.balance is number &&
             data.debt is number &&
             data.points is number &&
             data.completedModules is list &&
             data.achievements is list &&
             data.streak is number &&
             data.lastActive is string &&
             (!('publicKey' in data) || data.publicKey is string) &&
             (!('privateKey' in data) || data.privateKey is string) &&
             (!('codename' in data) || (data.codename is string && data.codename.size() <= 50));
    }

    function isValidForumPost(data) {
      return hasOnlyAllowedFields(['title', 'content', 'authorId', 'authorName', 'timestamp', 'replies']) &&
             data.title is string && data.title.size() < 200 &&
             data.content is string && data.content.size() < 10000 &&
             data.authorId is string &&
             data.authorName is string &&
             data.timestamp is string &&
             data.replies is number;
    }

    function isValidModule(data) {
      return hasOnlyAllowedFields(['id', 'title', 'description', 'category', 'difficulty', 'points', 'icon', 'scenario', 'educationalOutcome', 'redFlags', 'bestPractices', 'isActive']) &&
             data.id is string &&
             data.title is string &&
             data.points is number &&
             data.isActive is bool;
    }

    function isValidQuiz(data) {
      return hasOnlyAllowedFields(['id', 'moduleId', 'questions']) &&
             data.id is string &&
             data.moduleId is string &&
             data.questions is list;
    }

    function isValidProgress(data) {
      return hasOnlyAllowedFields(['userId', 'moduleId', 'status', 'quizScore', 'completedAt']) &&
             data.userId is string &&
             data.moduleId is string &&
             data.status in ['not-started', 'in-progress', 'completed'];
    }

    function isValidChatCode(data) {
      return hasOnlyAllowedFields(['code', 'vendorId', 'isActive', 'createdBy']) &&
             data.code is string && data.code.size() >= 8 && data.code.size() <= 12 &&
             data.vendorId is string &&
             data.isActive is bool &&
             data.createdBy is string;
    }

    function isValidChat(data) {
      return hasOnlyAllowedFields(['participants', 'lastMessage', 'updatedAt', 'typing']) &&
             data.participants is list &&
             data.participants.size() >= 2 &&
             (!('typing' in data) || data.typing is map);
    }

    function isValidMessage(data) {
      return hasOnlyAllowedFields(['chatId', 'senderId', 'text', 'timestamp', 'encrypted', 'read']) &&
             data.chatId is string &&
             data.senderId is string &&
             data.text is string && data.text.size() < 20000 &&
             data.encrypted is bool &&
             (!('read' in data) || data.read is bool);
    }

    function isValidMarketItem(data) {
      return hasOnlyAllowedFields(['title', 'price', 'category', 'vendorId', 'description', 'imageUrl', 'timestamp']) &&
             data.title is string && data.title.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.vendorId is string &&
             data.description is string && data.description.size() < 1000 &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 500)) &&
             (!('timestamp' in data) || data.timestamp is string);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && userId == request.auth.uid && isValidUser(request.resource.data) && request.resource.data.status == 'active' && request.resource.data.role == 'user';
      allow update: if isAuthenticated() && (
        (userId == request.auth.uid && 
         request.resource.data.status == resource.data.status && 
         request.resource.data.role == resource.data.role &&
         isValidUser(request.resource.data)) || 
        isAdmin()
      );
    }

    // Vendors
    match /vendors/{vendorId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Chat Codes
    match /chatCodes/{code} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Chats
    match /chats/{chatId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isAuthenticated() && isValidChat(request.resource.data) && (request.auth.uid in request.resource.data.participants || isAdmin());
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.participants || isAdmin());

      // Messages sub-collection
      match /messages/{messageId} {
        allow read: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isAdmin());
        allow create: if isAuthenticated() && isValidMessage(request.resource.data) && (request.auth.uid == request.resource.data.senderId || isAdmin());
        allow update: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isAdmin()) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      }
    }

    // Market Items
    match /marketItems/{itemId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMarketItem(request.resource.data) && (request.resource.data.vendorId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.vendorId == request.auth.uid);
    }

    // Training Modules
    match /modules/{moduleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Quizzes
    match /quizzes/{quizId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // User Progress
    match /userProgress/{progressId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidProgress(request.resource.data) && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && isValidProgress(request.resource.data) && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Forum Posts
    match /forumPosts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidForumPost(request.resource.data) && (request.resource.data.authorId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && isValidForumPost(request.resource.data) && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Services
    match /services/{serviceId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Settings
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
